<%# Toast notification partial - renders a single alert for the toast container %>
<%# locals: (message:, type: :notice, duration: 5000) %>
<%
  alert_class =
    case type.to_s
    when "notice", "success" then "alert-success"
    when "alert", "error" then "alert-error"
    when "warning" then "alert-warning"
    when "info" then "alert-info"
    else "alert-info"
    end

  icon_class =
    case type.to_s
    when "notice", "success" then "icon-[lucide--check-circle]"
    when "alert", "error" then "icon-[lucide--x-circle]"
    when "warning" then "icon-[lucide--alert-triangle]"
    else "icon-[lucide--info]"
    end
%>

<div
  data-controller="toast"
  data-toast-duration-value="<%= duration %>"
  data-toast-auto-dismiss-value="true"
  class="w-full max-w-sm">
  <div class="alert <%= alert_class %> shadow-lg" data-toast-target="alert">
    <span class="<%= icon_class %> size-5 shrink-0" aria-hidden="true"></span>
    <span class="flex-1"><%= message %></span>
    <button
      type="button"
      class="btn btn-ghost btn-xs btn-square"
      data-action="toast#dismiss"
      aria-label="Dismiss">
      <span class="icon-[lucide--x] size-4" aria-hidden="true"></span>
    </button>
  </div>
</div>
