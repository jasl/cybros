<nav class="h-full flex flex-col w-full">
  <div class="h-14 px-2 border-b border-base-300 flex items-center shrink-0 is-drawer-close:justify-center is-drawer-open:gap-2">
    <div class="is-drawer-close:hidden">
      <%= form_with url: conversations_path, method: :post do %>
        <button type="submit" class="btn btn-ghost btn-square" aria-label="New chat">
          <span class="icon-[lucide--square-pen] size-5"></span>
        </button>
      <% end %>
    </div>

    <div class="flex-1 is-drawer-close:hidden"></div>

    <div class="is-drawer-close:tooltip is-drawer-close:tooltip-right" data-tip="Toggle sidebar">
      <label for="left_drawer" class="btn btn-ghost btn-square" aria-label="Toggle sidebar">
        <span class="icon-[lucide--panel-left] size-5"></span>
      </label>
    </div>
  </div>

  <div class="px-2 is-drawer-open:hidden is-drawer-close:flex is-drawer-close:justify-center">
    <div class="is-drawer-close:tooltip is-drawer-close:tooltip-right" data-tip="New chat">
      <%= form_with url: conversations_path, method: :post do %>
        <button type="submit" class="btn btn-ghost btn-square" aria-label="New chat">
          <span class="icon-[lucide--square-pen] size-5"></span>
        </button>
      <% end %>
    </div>
  </div>

  <%= render "layouts/agent/sidebar_primary_nav" %>

  <div class="px-2 py-1 is-drawer-close:hidden">
    <div class="divider my-0"></div>
  </div>

  <%= render "layouts/agent/sidebar_conversations_section" %>

  <div class="flex-1 is-drawer-open:hidden"></div>

  <div class="border-t border-base-300 p-2">
    <div class="flex items-center gap-2 is-drawer-close:flex-col is-drawer-close:items-center">
      <div class="is-drawer-close:tooltip is-drawer-close:tooltip-right" data-tip="Toggle theme">
        <label class="btn btn-ghost btn-square swap swap-rotate" data-controller="theme" aria-label="Toggle theme">
          <input type="checkbox" data-theme-target="checkbox" data-action="change->theme#toggle" />
          <span class="icon-[lucide--sun] size-5 swap-off"></span>
          <span class="icon-[lucide--moon] size-5 swap-on"></span>
        </label>
      </div>

      <div class="flex-1 w-full is-drawer-close:flex is-drawer-close:justify-center">
        <div class="is-drawer-close:tooltip is-drawer-close:tooltip-right is-drawer-close:w-full is-drawer-close:flex is-drawer-close:justify-center" data-tip="Account">
          <%= render "_shared/account_dropdown",
                     placement_classes: "dropdown-top dropdown-end w-full",
                     trigger_classes: "btn btn-ghost btn-sm w-full gap-2 is-drawer-open:justify-start is-drawer-close:justify-center is-drawer-close:px-0 is-drawer-close:btn-square",
                     email_classes: "is-drawer-close:hidden flex-1 truncate text-left",
                     chevron_icon_class: "is-drawer-close:hidden icon-[lucide--chevron-up]",
                     user_icon_size_class: "size-5" %>
        </div>
      </div>
    </div>
  </div>
</nav>
